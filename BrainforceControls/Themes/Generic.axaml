<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BrainForceOne.BrainforceControls">
  
    <Design.PreviewWith>

        <Border Background="DarkGray" Padding="20">
                <Grid ColumnDefinitions="*,*,*,*">

                    <!-- ProgressRing control -->
                    <local:ProgressRingControl
                        StrokeThickness="33"
                        GlowEnabled="True"
                        GlowColor="#3B82F6"
                        GlowBlurRadius="24"
                        GlowOpacity="0.85"
                        Progress="50"
                        Subtitle="My Title"
                        FontFamily="{StaticResource RobotoMonoFont}"
                        Grid.Column="0" />

                    <!-- Speedometer control -->
                    <local:Speedometer
                        Width="300"
                        Height="300"
                        Position="Top"
                        GlassEffect="True"
                        SweepAngle="270"
                        Minimum="30.0"
                        Maximum="200.0"
                        TextSize="30"
                        UnitText="km/h"
                        UnitTextSize="12"
                        FontFamily="{StaticResource RobotoMonoFont}"
                        Value="65"
                        Grid.Column="1"/>
                    <!-- Thermometer control -->
                    <local:Thermometer
                        Width="150"
                        Height="400"
                        Minimum="0"
                        Maximum="120"
                        Value="90"
                        BulbSize="40"
                        StartColor="LimeGreen"
                        EndColor="Red"
                        ShowTicks="True"
                        Unit="°C"
                        TickInterval="10"
                        TickColor="Red"
                        TickPlacement="Left"
                        ValueTextColor="Red"
                        FontFamily="{StaticResource RobotoMonoFont}"
                        GlassEffect="True"
                         Grid.Column="2"/>
                    <local:LedDisplay
                        Width="300"
                        Height="200"
                        Digits="2"
                        Glow="True"
                        LeadingZeros="True"
                        SegmentOnColor="DarkRed"
                        SegmentThickness="0.7"
                        Value="20"
                        Grid.Column="3"/>
                </Grid>
            </Border>
    </Design.PreviewWith>
    <Style Selector="local|Speedometer">
        <Setter Property="FontFamily" Value="{StaticResource RobotoMonoFont}" />
    </Style>
     <Style Selector="local|Thermometer">

        <Setter Property="Width" Value="100"/>
        <Setter Property="Height" Value="500"/>

        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="Transparent"/>
            </ControlTemplate>
        </Setter>

    </Style>
    <Style Selector="local|LedDisplay">

    </Style>
    <Style Selector="local|ProgressRingControl">
        <Setter Property="FontFamily" Value="{StaticResource RobotoMonoFont}" />
    </Style>
    <Styles.Resources>
        <FontFamily x:Key="RobotoMonoFont">
          avares://BrainForceOne.BrainforceControls/Assets/Fonts/RobotoMono.ttf#Roboto Mono
        </FontFamily>
    </Styles.Resources>
  <!-- Include styles per control -->
  <StyleInclude Source="avares://BrainForceOne.BrainforceControls/Themes/ProgressRingControl.axaml" />
  <StyleInclude Source="avares://BrainForceOne.BrainforceControls/Themes/Speedometer.axaml" />
</Styles>
